#!/usr/bin/env bash
# Beat-sync wrapper — activates the Narrative venv and runs run.py.
# Add tools/beat-sync to PATH (via .zshrc) so this is callable from anywhere.
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
VENV="$REPO_ROOT/.venv/bin/activate"

if [[ -f "$VENV" ]]; then
  # shellcheck source=/dev/null
  source "$VENV"
fi

exec python "$SCRIPT_DIR/run.py" "$@"
