#!/usr/bin/env bash
# Render wrapper — activates the Narrative venv and runs render_ffmpeg.py.
REAL_SCRIPT="$(perl -MCwd -e 'print Cwd::realpath($ARGV[0])' "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(dirname "$REAL_SCRIPT")"
REPO_ROOT="$(cd "$SCRIPT_DIR/../../.." && pwd)"
VENV="$REPO_ROOT/.venv/bin/activate"

if [[ -f "$VENV" ]]; then
  # shellcheck source=/dev/null
  source "$VENV"
fi

exec python "$SCRIPT_DIR/render_ffmpeg.py" "$@"
